---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
---

<BaseLayout
  title="Over mij — Nils Mertens"
  description="Junior Fullstack Developer uit Antwerpen. Meer over Nils Mertens: achtergrond, opleiding en werkervaring."
>
  <div class="pt-16">
    <div class="container">

      <!-- Bio -->
      <section class="pb-16 border-b border-border last:border-none">
        <SectionHeader label="Profiel" title="Over Nils Mertens" />
        <div class="flex flex-col gap-4 max-w-180">
          <p class="text-foreground leading-[1.7]">
            Ik ben Nils — een junior developer uit Antwerpen met een brede interesse in alles wat
            met code te maken heeft. Van frontend tot backend, van pipelines tot scripts: ik vind
            het allemaal interessant. Mijn kijk op "fullstack" stopt niet bij UI en API — het
            omvat ook de lagen daaromheen: deployment, automatisering, infrastructuur.
          </p>
          <p class="text-foreground leading-[1.7]">
            Momenteel studeer ik nog aan AP Hogeschool, maar ik doe ondertussen al werkervaring
            op via stages en bijklussen. Alles wat ik bouw is publiek op GitHub — open source
            minded, hands-on aanpak.
          </p>
          <p class="text-foreground leading-[1.7]">
            Mijn DevOps kennis is grotendeels zelfgeleerd: toegepast op een eigen home server
            setup met Docker, Nginx en diverse zelf-gehoste services.
          </p>
          <div class="flex flex-col gap-2 mt-2 p-4 bg-card border border-border rounded-lg max-w-100">
            <div class="flex gap-4 items-center">
              <span class="text-[11px] font-medium uppercase tracking-[0.06em] text-foreground/50 min-w-20">Locatie</span>
              <span class="text-foreground">Antwerpen, België</span>
            </div>
            <div class="flex gap-4 items-center">
              <span class="text-[11px] font-medium uppercase tracking-[0.06em] text-foreground/50 min-w-20">E-mail</span>
              <a href="mailto:nilsdevmertens@gmail.com" class="text-primary hover:underline">nilsdevmertens@gmail.com</a>
            </div>
            <div class="flex gap-4 items-center">
              <span class="text-[11px] font-medium uppercase tracking-[0.06em] text-foreground/50 min-w-20">GitHub</span>
              <a href="https://github.com/Nils-Dev-Mertens" target="_blank" rel="noopener" class="text-primary hover:underline">
                Nils-Dev-Mertens
              </a>
            </div>
            <div class="flex gap-4 items-center">
              <span class="text-[11px] font-medium uppercase tracking-[0.06em] text-foreground/50 min-w-20">Status</span>
              <span class="inline-block py-0.5 px-2.5 rounded-full text-[11px] font-medium uppercase tracking-[0.06em] text-primary bg-primary/10 border border-primary/30">
                Open voor freelance
              </span>
            </div>
          </div>
        </div>
      </section>

      <!-- Skills -->
      <section class="py-16 border-b border-border">
        <SectionHeader label="Vaardigheden" title="Technische stack" />
        <SkillsGrid />
      </section>

      <!-- Work experience -->
      <section class="py-16 border-b border-border">
        <SectionHeader label="Werkervaring" title="Waar ik gewerkt heb" />
        <div class="border-l-2 border-white/8 pl-8 ml-2 flex flex-col">
          {[
            { type: 'Stage', period: 'Juli 2025 – Augustus 2025', company: 'ZORGI', role: 'Test Automation Engineer', desc: 'Werkte als test automation engineer binnen een zorggerelateerde applicatieomgeving. Schrijven en uitvoeren van geautomatiseerde end-to-end tests, integratie met CI/CD pipeline.' },
            { type: 'Freelance', period: 'Juni 2024 – November 2024', company: 'WEXSO BV', role: 'Lead Media/Web', desc: 'Lead rol in media en webontwikkeling. Verantwoordelijk voor frontend development, contentontwikkeling en technisch beheer van webprojecten.' },
            { type: 'Opdracht', period: 'Februari 2024', company: 'Adminesstration.be', role: 'Media/Web', desc: 'Kortlopende media/web opdracht.' },
          ].map((job) => (
            <div class="relative pb-8 last:pb-0">
              <div class="absolute -left-9.25 top-1 size-2.5 rounded-full bg-pink border-2 border-background" />
              <div class="flex flex-col gap-2">
                <div class="flex gap-4 items-center">
                  <span class="tag">{job.type}</span>
                  <span class="text-[11px] font-medium text-foreground/50">{job.period}</span>
                </div>
                <h3 class="text-xl font-medium text-primary">{job.company}</h3>
                <p class="text-foreground/70 italic">{job.role}</p>
                <p class="text-foreground leading-relaxed max-w-150">{job.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section class="py-16">
        <SectionHeader label="Opleiding" title="Achtergrond" />
        <div class="border-l-2 border-white/8 pl-8 ml-2 flex flex-col">
          {[
            { company: 'AP Hogeschool — Antwerpen', role: 'Graduaat Programmeren', desc: 'Technische opleiding gericht op softwareontwikkeling. Focus op fullstack development, OOP en projectwerk.' },
            { company: 'Cadix — Noorderlaan, Antwerpen', role: 'Opleiding Multimedia', desc: 'Opleiding met focus op multimedia, web en digitale media.' },
          ].map((edu) => (
            <div class="relative pb-8 last:pb-0">
              <div class="absolute -left-9.25 top-1 size-2.5 rounded-full bg-pink border-2 border-background" />
              <div class="flex flex-col gap-2">
                <h3 class="text-xl font-medium text-primary">{edu.company}</h3>
                <p class="text-foreground/70 italic">{edu.role}</p>
                <p class="text-foreground leading-relaxed max-w-150">{edu.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
