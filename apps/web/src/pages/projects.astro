---
import { getProjects } from '@portfolio/data';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';

const projects = getProjects();
---

<BaseLayout
  title="Projecten — Nils Mertens"
  description="Alle open source projecten van Nils Mertens: web apps, CLI tools, DevOps setups en automatiseringsscripts."
>
  <section class="pt-16">
    <div class="container">
      <SectionHeader label="Portfolio" title="Alle projecten" />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
