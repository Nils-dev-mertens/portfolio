---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projecten' },
  { href: '/about', label: 'Over mij' },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-background border-b border-border">
  <div class="container flex items-center justify-between h-15">
    <a href="/" class="text-xl font-bold text-primary">
      NM<span class="text-pink">.</span>
    </a>
    <nav>
      <ul class="flex gap-8 list-none">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-[11px] font-medium uppercase tracking-[0.08em] transition-colors duration-150',
                current === link.href
                  ? 'text-primary'
                  : 'text-foreground hover:text-primary',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
