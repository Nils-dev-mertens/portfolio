---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projecten' },
  { href: '/about', label: 'Over mij' },
];

const current = Astro.url.pathname;
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">NM<span class="nav__logo-dot">.</span></a>
    <nav>
      <ul class="nav__links">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav__link', { 'nav__link--active': current === link.href }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: var(--border-subtle);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav__logo {
    font: 700 20px/1 var(--font-base);
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav__logo-dot {
    color: var(--color-accent);
  }

  .nav__links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav__link {
    font: var(--text-label);
    font-family: var(--font-base);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--color-primary);
    text-decoration: none;
  }
</style>
