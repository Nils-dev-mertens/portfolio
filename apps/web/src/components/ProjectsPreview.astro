---
import { getProjects } from '../../../../packages/data';
import SectionHeader from './SectionHeader.astro';
import ProjectCard from './ProjectCard.astro';

const projects = getProjects({ featured: true, limit: 3 });

// Preview bento — distinct from the /projects page:
// Row 1: [col-5 compact] [col-7 wide]   ← compact leads, featured lands on right
// Row 2: [col-12 wide]                   ← full-width showcase closer
const spans: Array<{ col: string; wide: boolean }> = [
  { col: 'md:col-span-5', wide: false },
  { col: 'md:col-span-7', wide: false  },
  { col: 'md:col-span-12', wide: false  },
];
---

<section class="py-16">
  <div class="container">
    <SectionHeader
      label="Projecten"
      title="Wat ik bouw"
      ctaHref="/projects"
      ctaLabel="Alle projecten"
    />
    <div class="grid grid-cols-12 gap-4 items-stretch">
      {projects.map((project, i) => {
        const { col, wide } = spans[i] ?? { col: 'md:col-span-4', wide: false };
        return (
          <div class={`col-span-12 ${col} h-full`}>
            <ProjectCard project={project} wide={wide} />
          </div>
        );
      })}
    </div>
  </div>
</section>
