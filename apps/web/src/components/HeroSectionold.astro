<section class="py-16 border-b border-border">
  <div class="container grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div>
      <span class="inline-block text-[11px] font-medium uppercase tracking-[0.08em] text-pink mb-4">
        Junior Fullstack Developer
      </span>
      <h1 class="text-[40px] md:text-[56px] font-bold leading-[1.05] text-primary mb-4">
        Nils Mertens
      </h1>
      <p class="text-foreground max-w-120 mb-8 leading-[1.7]">
        Code, Automate, Deploy — van frontend tot infra, van pipelines tot scripts.
        Alles open source op GitHub.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/projects" class="btn btn-primary">Bekijk projecten</a>
        <a href="/about" class="btn btn-ghost">Over mij</a>
      </div>
    </div>

    <div class="hidden md:block bg-card border border-border rounded-lg overflow-hidden font-mono text-sm" aria-hidden="true">
      <div class="flex items-center gap-2 px-4 py-2 bg-white/4 border-b border-border">
        <span class="size-3 rounded-full bg-[#ff5f57]"></span>
        <span class="size-3 rounded-full bg-[#ffbd2e]"></span>
        <span class="size-3 rounded-full bg-[#28c840]"></span>
        <span class="text-[11px] font-medium text-foreground/50 ml-auto">nils@vps:~</span>
      </div>
      <div class="p-4 flex flex-col gap-1 leading-relaxed">
        <p><span class="text-foreground/40">$</span> <span class="text-primary">whoami</span></p>
        <p class="text-foreground pl-4">nils-mertens</p>
        <p><span class="text-foreground/40">$</span> <span class="text-primary">cat skills.txt</span></p>
        <p class="text-foreground pl-4">TypeScript · Python · C# · Bash</p>
        <p class="text-foreground pl-4">React · Vue · Node.js · .NET</p>
        <p class="text-foreground pl-4">Docker · CI/CD · Playwright</p>
        <p><span class="text-foreground/40">$</span> <span class="text-primary">echo $STATUS</span></p>
        <p class="text-pink pl-4">open voor freelance &amp; bijklussen</p>
        <p><span class="text-foreground/40">$</span> <span class="text-primary animate-blink">_</span></p>
      </div>
    </div>
  </div>
</section>
