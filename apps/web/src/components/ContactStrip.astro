---
import { ContactButtons } from "./ContactButtons";
---

<footer class="relative pt-20 pb-8 overflow-hidden">
  <!-- Atmospheric gradient from bottom -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_120%_60%_at_50%_100%,rgba(216,95,163,0.1),transparent_70%)]"
    aria-hidden="true"
  ></div>

  <div class="container">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10">
      <div class="flex flex-col gap-4">
        <span class="block text-[11px] font-medium uppercase tracking-[0.08em] text-pink mb-2">
          Beschikbaar voor werk
        </span>
        <h2 class="text-4xl md:text-5xl font-bold leading-tight text-primary">
          Laten we iets<br />bouwen samen.
        </h2>
        <p class="text-foreground/50 text-sm leading-relaxed max-w-sm">
          Open voor freelance projecten, samenwerkingen en vaste rollen.
        </p>
      </div>
      <ContactButtons client:idle />
    </div>
  </div>
</footer>
