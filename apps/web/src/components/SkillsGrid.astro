---
import SkillBadge from './SkillBadge.astro';

const skillCategories = [
  {
    label: 'Talen',
    skills: ['JavaScript', 'TypeScript', 'Python', 'Java', 'C#', 'Bash'],
  },
  {
    label: 'Frontend',
    skills: ['React', 'Vue', 'Angular', 'Astro', 'HTML/CSS'],
  },
  {
    label: 'Backend & Runtime',
    skills: ['Node.js', '.NET', 'ASP.NET', 'REST API', 'Bun'],
  },
  {
    label: 'DevOps & Infra',
    skills: ['Docker', 'Kubernetes', 'GitHub Actions', 'Jenkins', 'Linux', 'Nginx', 'AWS', 'Azure'],
  },
  {
    label: 'Test Automation',
    skills: ['Playwright', 'Selenium', 'Cypress'],
  },
];
---

<div class="flex flex-col gap-8">
  {skillCategories.map((cat) => (
    <div>
      <span class="block text-[11px] font-medium uppercase tracking-[0.08em] text-pink mb-2">
        {cat.label}
      </span>
      <div class="flex flex-wrap gap-2">
        {cat.skills.map((skill) => <SkillBadge name={skill} />)}
      </div>
    </div>
  ))}
</div>
