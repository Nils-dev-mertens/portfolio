---
import { getWorkExperience } from '../../../../packages/data';

const jobs = getWorkExperience();

function formatPeriod(start: string, end: string | null, current: boolean) {
  const fmt = (d: string) =>
    new Date(d).toLocaleDateString('nl-NL', { month: 'short', year: 'numeric' });
  const endLabel = current ? 'heden' : end ? fmt(end) : '';
  return `${fmt(start)} – ${endLabel}`;
}
---

<section class="border-t border-border py-16">
  <div class="container">
    <div class="mb-8">
      <span class="block text-[11px] font-medium uppercase tracking-[0.08em] text-pink mb-2">
        Werkervaring
      </span>
      <h2 class="text-[30px] font-bold leading-tight text-primary">Waar ik gewerkt heb</h2>
    </div>

    <div class="flex flex-col">
      {jobs.map((job, i) => (
        <div class={`job-row group relative flex items-start gap-4 py-4 px-3 -mx-3 rounded-md cursor-default ${i !== 0 ? 'border-t border-border' : ''}`}>

          <!-- Left accent bar (revealed on hover) -->
          <div class="accent-bar absolute left-0 top-3 bottom-3 w-0.5 rounded-full bg-pink opacity-0 transition-opacity duration-200" />

          <!-- Company initial avatar -->
          <div class="shrink-0 size-9 rounded-md bg-card border border-border flex items-center justify-center text-sm font-bold text-foreground/80">
            {job.company.charAt(0).toUpperCase()}
          </div>

          <!-- Main content -->
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-sm font-semibold text-foreground">
                  {job.company}
                </span>
                <span class="text-foreground/40 text-xs">·</span>
                <span class="text-xs text-foreground/70 italic">{job.role}</span>
                {job.current && (
                  <span class="tag bg-pink/10 text-pink border-pink/20 text-[10px] py-0 leading-5">Huidig</span>
                )}
              </div>
              <span class="text-[11px] text-foreground/55 shrink-0 tabular-nums">
                {formatPeriod(job.start_date, job.end_date, job.current)}
              </span>
            </div>

            {job.description && (
              <p class="text-sm text-foreground/75 leading-relaxed mt-1">{job.description}</p>
            )}

            {job.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-2">
                {job.tags.map((tag) => (
                  <span class="inline-block py-0.5 px-2 rounded text-[10px] font-medium uppercase tracking-[0.05em] text-foreground/60 bg-white/5 border border-white/10">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .job-row {
    transition: background-color 250ms ease;
  }

  .job-row:hover {
    background-color: rgba(255, 255, 255, 0.018);
  }

  .job-row:hover .accent-bar {
    opacity: 1;
  }
</style>
