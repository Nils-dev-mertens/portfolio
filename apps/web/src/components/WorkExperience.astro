---
const jobs = [
  {
    company: 'ZORGI',
    role: 'Test Automation Engineer',
    period: 'Juli 2025 – Augustus 2025',
    type: 'Stage',
    description:
      'Test automation engineer binnen een zorggerelateerde applicatieomgeving. Schrijven en uitvoeren van geautomatiseerde end-to-end tests.',
    tags: ['Playwright', 'Test Automation', 'CI/CD'],
  },
  {
    company: 'WEXSO BV',
    role: 'Lead Media/Web',
    period: 'Juni 2024 – November 2024',
    type: 'Freelance',
    description:
      'Lead rol in media en webontwikkeling. Verantwoordelijk voor frontend development, contentontwikkeling en technisch beheer van webprojecten.',
    tags: ['Web Development', 'Frontend', 'Media'],
  },
  {
    company: 'Adminesstration.be',
    role: 'Media/Web',
    period: 'Februari 2024',
    type: 'Opdracht',
    description: 'Kortlopende media/web opdracht.',
    tags: ['Web', 'Media'],
  },
];
---

<section class="border-t border-border py-16">
  <div class="container">
    <div class="mb-8">
      <span class="block text-[11px] font-medium uppercase tracking-[0.08em] text-pink mb-2">
        Werkervaring
      </span>
      <h2 class="text-[30px] font-bold leading-tight text-primary">Waar ik gewerkt heb</h2>
    </div>

    <div class="border-l-2 border-white/8 pl-8 ml-2 flex flex-col">
      {jobs.map((job) => (
        <div class="relative pb-8 last:pb-0">
          <div class="absolute -left-9.25 top-1 size-2.5 rounded-full bg-pink border-2 border-background" />
          <div class="flex flex-col gap-2">
            <div class="flex gap-4 items-center">
              <span class="tag">{job.type}</span>
              <span class="text-[11px] font-medium text-foreground/50">{job.period}</span>
            </div>
            <h3 class="text-xl font-medium text-primary">{job.company}</h3>
            <p class="text-foreground/70 italic">{job.role}</p>
            <p class="text-foreground leading-relaxed max-w-150">{job.description}</p>
            <div class="flex flex-wrap gap-1">
              {job.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
