---
import SectionHeader from './SectionHeader.astro';
import SkillsGrid from './SkillsGrid.astro';
---

<section class="about-preview">
  <div class="container">
    <SectionHeader
      label="Over mij"
      title="Wie is Nils?"
      ctaHref="/about"
      ctaLabel="Lees meer"
    />

    <div class="about-preview__inner">
      <div class="about-preview__bio">
        <p>
          Ik ben Nils — een junior developer uit Antwerpen met een brede interesse in alles wat
          met code te maken heeft. Van frontend tot backend, van pipelines tot scripts: ik vind
          het allemaal interessant.
        </p>
        <p>
          Momenteel studeer ik nog, maar doe ondertussen al werkervaring op via stages en bijklussen.
          Mijn DevOps kennis is grotendeels zelfgeleerd — toegepast op mijn eigen home server setup.
        </p>
        <p>
          Alles wat ik bouw is publiek op <a href="https://github.com/Nils-Dev-Mertens" target="_blank" rel="noopener">GitHub</a>.
          Open source minded, hands-on aanpak.
        </p>
        <div class="about-preview__meta">
          <span class="meta-item">📍 Antwerpen, België</span>
          <span class="meta-item">🎓 AP Hogeschool</span>
          <span class="meta-item status-badge">Open voor freelance</span>
        </div>
      </div>

      <div class="about-preview__skills">
        <SkillsGrid />
      </div>
    </div>
  </div>
</section>

<style>
  .about-preview__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .about-preview__bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-preview__bio p {
    color: var(--color-text);
    line-height: 1.7;
  }

  .about-preview__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    align-items: center;
  }

  .meta-item {
    font: var(--text-label);
    font-family: var(--font-base);
    color: var(--color-text);
    opacity: 0.7;
  }

  .status-badge {
    padding: 2px 10px;
    border-radius: var(--radius-badge);
    background-color: rgba(245, 208, 96, 0.1);
    border: 1px solid rgba(245, 208, 96, 0.3);
    color: var(--color-primary);
    opacity: 1;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .about-preview__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
