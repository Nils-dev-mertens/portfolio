---
import type { Project } from '@portfolio/data';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card">
  <div class="project-card__top">
    <h3 class="project-card__title">{project.title}</h3>
    <div class="project-card__links">
      {project.repo_url && (
        <a href={project.repo_url} target="_blank" rel="noopener" class="project-card__link" title="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}
      {project.url && (
        <a href={project.url} target="_blank" rel="noopener" class="project-card__link" title="Live">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      )}
    </div>
  </div>

  <p class="project-card__desc">{project.description}</p>

  <div class="project-card__tags">
    {project.tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</article>

<style>
  .project-card {
    background-color: var(--color-surface);
    border: var(--border-subtle);
    border-radius: var(--radius-card);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: border-color 0.15s;
  }

  .project-card:hover {
    border-color: var(--color-accent);
  }

  .project-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .project-card__title {
    font: var(--text-h2);
    font-family: var(--font-base);
    color: var(--color-primary);
  }

  .project-card__links {
    display: flex;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .project-card__link {
    color: var(--color-text);
    opacity: 0.5;
    transition: opacity 0.15s;
    display: flex;
    align-items: center;
  }

  .project-card__link:hover {
    opacity: 1;
    color: var(--color-primary);
    text-decoration: none;
  }

  .project-card__desc {
    color: var(--color-text);
    font: var(--text-body);
    flex: 1;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    display: inline-block;
    padding: 2px 10px;
    border-radius: var(--radius-badge);
    font: var(--text-label);
    font-family: var(--font-base);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background-color: rgba(216, 95, 163, 0.1);
    border: 1px solid rgba(216, 95, 163, 0.25);
  }
</style>
