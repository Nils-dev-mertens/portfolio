---
interface Props {
  label: string;
  title: string;
  ctaHref?: string;
  ctaLabel?: string;
  as?: 'h1' | 'h2';
}

const { label, title, ctaHref, ctaLabel, as: Tag = 'h2' } = Astro.props;
---

<div class="flex items-end justify-between mb-8 flex-wrap gap-4">
  <div>
    <span class="block text-[11px] font-medium uppercase tracking-[0.08em] text-pink mb-2">
      {label}
    </span>
    <Tag class="text-[30px] font-bold leading-tight text-primary">{title}</Tag>
  </div>
  {ctaHref && (
    <a
      href={ctaHref}
      class="text-[11px] font-medium uppercase tracking-[0.08em] text-pink whitespace-nowrap transition-colors duration-150 hover:text-primary"
    >
      {ctaLabel} →
    </a>
  )}
</div>
