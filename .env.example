# Portfolio Website - Environment Variables

# Database configuration
DB_PATH=./portfolio.db

# Web server configuration
HOST=0.0.0.0
PORT=4321

# Development mode (set to 'development' for dev, 'production' for prod)
NODE_ENV=development

# API configuration (if using separate API service)
API_URL=http://localhost:3000

# GitHub activity (if applicable)
GITHUB_USERNAME=
GITHUB_TOKEN=

# Analytics (if applicable)
ANALYTICS_ID=

# Note: For Docker deployment, these variables are typically set in docker-compose.yml
# This file serves as documentation for local development